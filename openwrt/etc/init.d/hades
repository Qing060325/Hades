#!/bin/sh /etc/rc.common
# Hades proxy kernel - procd init script

START=60
STOP=40

USE_PROCD=1

PROG=/usr/bin/hades
CONF_DIR=/etc/hades
PID_FILE=/var/run/hades.pid
LOG_FILE=/var/log/hades.log

start_service() {
	local config_enable
	local config_path
	local api_listen
	local api_secret
	local log_level

	config_load hades

	config_get config_enable config enable '1'
	config_get config_path config config_path "${CONF_DIR}/config.yaml"
	config_get api_listen config api_listen '127.0.0.1:9090'
	config_get api_secret config api_secret ''
	config_get log_level config log_level 'info'

	# 检查是否启用
	if [ "$config_enable" != "1" ]; then
		echo "Hades is disabled in /etc/config/hades"
		return 1
	fi

	# 检查配置文件
	if [ ! -f "$config_path" ]; then
		echo "Config file not found: $config_path"
		return 1
	fi

	# 检查二进制
	if [ ! -x "$PROG" ]; then
		echo "Hades binary not found: $PROG"
		return 1
	fi

	# 创建日志目录
	mkdir -p /var/log

	procd_open_instance hades
	procd_set_param command "$PROG" -c "$config_path"
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param pidfile "$PID_FILE"
	procd_set_param limits nofile="65535:65535"
	procd_close_instance

	echo "Hades started (config: $config_path)"
}

stop_service() {
	# 优雅关闭，等待 5 秒
	local pid
	if [ -f "$PID_FILE" ]; then
		pid=$(cat "$PID_FILE")
		if kill -0 "$pid" 2>/dev/null; then
			kill -TERM "$pid"
			local i=0
			while [ $i -lt 50 ]; do
				kill -0 "$pid" 2>/dev/null || break
				sleep 0.1
				i=$((i + 1))
			done
			kill -0 "$pid" 2>/dev/null && kill -KILL "$pid"
		fi
		rm -f "$PID_FILE"
	fi
}

service_triggers() {
	procd_add_reload_trigger "hades"
}

reload_service() {
	stop
	start
}
